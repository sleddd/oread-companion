# Environment Configuration for Oread Chat Interface

# Application
NODE_ENV=development
PORT=3001

# Session Secret (REQUIRED in production - generate with: openssl rand -base64 32)
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Encryption Passphrase (REQUIRED in production - generate with: openssl rand -base64 32)
OREAD_ENCRYPTION_PASSPHRASE=change-this-to-a-random-passphrase-in-production

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama2
OLLAMA_EMBED_MODEL=nomic-embed-text

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload Limits
MAX_UPLOAD_SIZE=2mb

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_MAX=10

# Security
ENABLE_AUTH=false
ENABLE_CSRF=true

# Logging
LOG_LEVEL=info
