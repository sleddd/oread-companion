# Dependencies
node_modules/
client/node_modules/

# User data (exclude user customizations, keep defaults)
# Keep: /data/characters/defaults/, /data/lorebook/, /data/avatars/, /data/settings/defaults/
# Exclude: user settings, user characters, database, vector store

# Exclude user settings (but keep defaults folder)
/data/settings/*.json

# Exclude user characters (but keep defaults folder)
/data/characters/*.json

# Exclude database files
/data/chat.db
/data/chat.db-shm
/data/chat.db-wal

# Exclude vector store
/data/vector-store/

# Exclude session encryption key
/.oread-chat-key

# Keep these folders (they should be in git):
# /data/characters/defaults/  - Default character templates
# /data/lorebook/             - Personality trait templates
# /data/avatars/              - Default avatar images

# Environment variables
.env
.env.local

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build outputs
client/dist/
client/build/

# Temporary files
*.tmp
*.temp
