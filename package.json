    "@modelcontextprotocol/sdk": "^1.27.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "langchain": "^1.2.31",
    "ollama": "^0.6.3",
    "openai": "^6.29.0",
